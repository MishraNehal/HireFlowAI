APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-this

# ─────────────────────────────────────────────────────────
# Supabase PostgreSQL
# Get from: supabase.com → Project → Settings → Database → URI
# ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST].supabase.co:5432/postgres

# ─────────────────────────────────────────────────────────
# Upstash Redis
# Get from: upstash.com → Database → Details → UPSTASH_REDIS_URL
# Must start with rediss:// (double-s for TLS)
# ─────────────────────────────────────────────────────────
REDIS_URL=rediss://default:[YOUR-PASSWORD]@[YOUR-HOST].upstash.io:[PORT]

# ─────────────────────────────────────────────────────────
# Groq LLM
# Get from: console.groq.com → API Keys
# ─────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# ─────────────────────────────────────────────────────────
# Clerk Authentication
# Get from: dashboard.clerk.com → API Keys
# ─────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────
# Deepgram (Real-time Speech-to-Text)
# Get from: console.deepgram.com → API Keys
# ─────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────
# ElevenLabs (Text-to-Speech)
# Get from: elevenlabs.io → Profile → API Key
# Voice ID: get from elevenlabs.io → Voice Library → copy ID
# ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─────────────────────────────────────────────────────────
# Daily.co (WebRTC Video)
# Get from: dashboard.daily.co → Developers → API Keys
# ─────────────────────────────────────────────────────────
DAILY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────
# Cloudflare R2 (File Storage)
# Get from: cloudflare.com → R2 → Manage R2 API Tokens
# Endpoint format: https://[ACCOUNT-ID].r2.cloudflarestorage.com
# ─────────────────────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_R2_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_R2_ENDPOINT=https://[ACCOUNT-ID].r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=hireflow

# ─────────────────────────────────────────────────────────
# SendGrid (Email Delivery)
# Get from: app.sendgrid.com → Settings → API Keys
# ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ─────────────────────────────────────────────────────────
# Twilio SMS — OPTIONAL
# If not provided, SMS content will be printed to console instead
# Get from: console.twilio.com
# ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─────────────────────────────────────────────────────────
# Google Calendar — OPTIONAL
# If not provided, mock time slots will be generated
# Get from: console.cloud.google.com → Credentials → OAuth 2.0
# ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────
# LangSmith (Agent Monitoring)
# Get from: smith.langchain.com → Settings → API Keys
# ─────────────────────────────────────────────────────────
LANGSMITH_API_KEY=lsv2_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=hireflow-ai

# ─────────────────────────────────────────────────────────
# Judge0 (Code Execution for Coding Round)
# Get from: judge0.com → RapidAPI → Subscribe to free tier
# ─────────────────────────────────────────────────────────
JUDGE0_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# ─────────────────────────────────────────────────────────
# Embedding Model (local — no key needed)
# ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
